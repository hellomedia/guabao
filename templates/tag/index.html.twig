{% extends 'base.html.twig' %}

{% block title %}Tags{% endblock %}

{% block body %}

<h1>Tags</h1>

{% for tag in tags %}
    <div>
        <p>
            <a href="{{ path('tag_show', { slug: tag.slug }) }}">
                {{ tag.name }} ({{ tag.videos|length }})
            </a>
        </p>
    </div>
{% endfor %}

{% endblock %}
